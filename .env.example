# ─────────────────────────────────────────────────────────────
# Orbit - environment variables
# Copy to .env and fill in. Validated at runtime by zod (packages/shared).
# ─────────────────────────────────────────────────────────────

# AI (DeepSeek, OpenAI-compatible - swappable via AI_BASE_URL)
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=
AI_MODEL_CHAT=deepseek-chat
AI_MODEL_REASONER=deepseek-reasoner

# 0G Chain + server wallet (gas for Storage + attestation)
SERVER_PRIVATE_KEY=
ZG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602

# 0G Storage
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
ZG_STORAGE_FLOW=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
ZG_STORAGE_MINE=0x00A9E9604b0538e06b268Fb297Df333337f9593b
ZG_STORAGE_REWARD=0xA97B57b4BdFEA2D0a25e535bd849ad4e6C440A69

# 0G DA / attestation
ZG_DA_ENTRANCE=0xE75A073dA5bb7b0eC622170Fd268f35E675a957B
ORBIT_ATTESTATION_ADDRESS=
ATTESTATION_SIGN_DEADLINE_MS=604800000

# X (twitterapi.io)
X_API_KEY=
GLOBAL_POLL_INTERVAL_MS=600000
X_POLL_MAX_PAGES=1
AI_BATCH_SIZE=5

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Webapp
JWT_SECRET=
NEXT_PUBLIC_AGENT_BASE_URL=http://127.0.0.1:4000
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Agent
INTERNAL_API_SECRET=
AGENT_HOST=127.0.0.1
AGENT_PORT=4000
DB_PATH=./data/orbit.db
LOG_LEVEL=info

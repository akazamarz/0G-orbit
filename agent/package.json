{
  "name": "@orbit/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../.env --import tsx --watch src/index.ts",
    "build": "tsup",
    "start": "node --env-file=../.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --env-file=../.env --import tsx --test src/**/*.test.ts",
    "wallet-storage": "node --env-file=../.env --import tsx src/scripts/wallet-storage.ts"
  },
  "dependencies": {
    "@orbit/shared": "workspace:*",
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.6",
    "better-sqlite3": "^11.7.0",
    "ethers": "^6.13.4",
    "grammy": "^1.34.0",
    "hono": "^4.6.16",
    "@hono/node-server": "^1.13.7",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
